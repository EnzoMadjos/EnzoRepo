# SF QA Relay — configuration
# Copy this file to .env and fill in the values.

# Shared secret — must match RELAY_TOKEN in Vanessa's app .env
# Generate a strong random string, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"
RELAY_TOKEN=

# Port the relay server listens on locally (ngrok will forward to this)
RELAY_PORT=9100

# Optional: path to patch.zip (default: relay/patch.zip in the same folder)
# PATCH_FILE=patch.zip

# Optional: version string shown in the UI (e.g. "1.2.0")
# APP_VERSION=
