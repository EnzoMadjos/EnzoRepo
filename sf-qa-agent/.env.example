# LLM (local Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Optional: change the port the app listens on
APP_PORT=8200

# NOTE: Salesforce credentials are entered at login — not stored here.

# ── Live relay (primary) ────────────────────────────────────────────────────
# Start relay/relay_server.py on your machine, expose with ngrok, paste URL here.
# When set, this is used for both log reporting and updates.
# Leave blank to fall back to the static options below.
RELAY_URL=
RELAY_TOKEN=

# ── Fallback: static patch URL (Google Drive direct-download) ────────────────
UPDATE_URL=

# ── Fallback: Discord or Slack webhook ──────────────────────────────────────
LOG_WEBHOOK_URL=
