# PITOGO Barangay App — Environment

# App
APP_NAME=PITOGO Barangay App
APP_PORT=8300

# Peer discovery (defaults are fine, change only if you have port conflicts)
DISCOVERY_PORT=50300
DISCOVERY_TIMEOUT_SEC=2.0
HEARTBEAT_INTERVAL=5.0
HEARTBEAT_MISSES=3

# Support relay (filled in from the Support button at runtime)
RELAY_URL=
RELAY_TOKEN=

# Fallback: Discord or Slack webhook for log reports (optional)
LOG_WEBHOOK_URL=
