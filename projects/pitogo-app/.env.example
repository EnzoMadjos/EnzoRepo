# ──────────────────────────────────────────────────────────────────────────────
# PITOGO Barangay App — Environment Example
# Copy to .env and fill in values. The install scripts do this automatically.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=PITOGO Barangay App
APP_PORT=8300

# ── Node role ─────────────────────────────────────────────────────────────────
# leader  → runs PostgreSQL + app (the main office PC)
# client  → app only, connects to leader's PostgreSQL over LAN
NODE_ROLE=leader

# ── Database ──────────────────────────────────────────────────────────────────
# DB_BACKEND: postgres (default) | sqlite (emergency fallback only)
DB_BACKEND=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pitogo
DB_USER=pitogo
DB_PASS=                 # auto-generated by install_leader — never commit this

# ── Peer discovery ────────────────────────────────────────────────────────────
DISCOVERY_PORT=50300
DISCOVERY_TIMEOUT_SEC=2.0
HEARTBEAT_INTERVAL=5.0
HEARTBEAT_MISSES=3

# ── Support relay ─────────────────────────────────────────────────────────────
RELAY_URL=
RELAY_TOKEN=

# ── Fallback notifications ────────────────────────────────────────────────────
LOG_WEBHOOK_URL=

# ── Updates ───────────────────────────────────────────────────────────────────
UPDATE_URL=
PATCH_PUBLIC_KEY_PATH=
DOWNLOAD_SECRET=
