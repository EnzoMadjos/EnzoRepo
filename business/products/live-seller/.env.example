# ── Live Seller App — Environment Config ─────────────────────────
# Copy this to .env and fill in your values.
# Only set what you need — all values have sensible defaults.

# ── Server ───────────────────────────────────────────────────────
# LIVE_SELLER_HOST=0.0.0.0
# LIVE_SELLER_PORT=8500
# LIVE_SELLER_DEBUG=false

# ── Store Identity ────────────────────────────────────────────────
LIVE_SELLER_STORE_NAME=My Live Store

# ── Ollama (local LLM — primary) ─────────────────────────────────
# LIVE_SELLER_OLLAMA_URL=http://localhost:11434
# LIVE_SELLER_OLLAMA_MODEL=phi4-mini
# LIVE_SELLER_OLLAMA_TIMEOUT=10
# LIVE_SELLER_OLLAMA_MAX_RETRIES=3

# ── GitHub Models API (cloud fallback) ───────────────────────────
# Get token from: https://github.com/settings/tokens
# LIVE_SELLER_GITHUB_TOKEN=ghp_your_token_here
# LIVE_SELLER_GITHUB_MODEL=meta/Llama-3.3-70B-Instruct

# ── Batch / Pipeline ─────────────────────────────────────────────
# LIVE_SELLER_BATCH_WINDOW_SECONDS=30
# LIVE_SELLER_BATCH_MAX_COMMENTS=20
# LIVE_SELLER_CLIPBOARD_POLL_INTERVAL=3.0

# ── Order Confidence Thresholds ───────────────────────────────────
# Orders ≥ this confidence are AUTO-confirmed + printed (0.0 - 1.0)
# LIVE_SELLER_CONFIDENCE_AUTO_CONFIRM=0.85
# Orders below this are silently ignored
# LIVE_SELLER_CONFIDENCE_REVIEW_THRESHOLD=0.60

# ── Thermal Printer ──────────────────────────────────────────────
# Set to false to disable printing (dry-run mode — logs instead)
# LIVE_SELLER_PRINTER_ENABLED=true
# USB vendor/product IDs (hex or decimal)
# Run: python -c "import usb.core; print([(hex(d.idVendor), hex(d.idProduct)) for d in usb.core.find(find_all=True)])"
# LIVE_SELLER_PRINTER_VENDOR_ID=0x0416
# LIVE_SELLER_PRINTER_PRODUCT_ID=0x5011

# ── Bidding Defaults ─────────────────────────────────────────────
# LIVE_SELLER_BID_COUNTDOWN_DEFAULT_SECONDS=60
# LIVE_SELLER_BID_MIN_INCREMENT_DEFAULT=10.0
